generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum MarketType {
  INDIA
  FOREX
}

enum SignalAction {
  BUY
  SELL
  HOLD
}

enum TradeDirection {
  BUY
  SELL
}

enum TradeTag {
  FOMO
  REVENGE
  LATE_ENTRY
  PERFECT_TRADE
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  role         Role       @default(USER)
  status       AccountStatus @default(PENDING)
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  country      String?
  experience   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userAlgos    UserAlgo[]
  journalEntries TradeJournalEntry[]
  impersonationsAsAdmin  ImpersonationLog[] @relation("ImpersonationAdmin")
  impersonationsAsTarget ImpersonationLog[] @relation("ImpersonationTarget")

  @@map("users")
}

model Algo {
  id             String       @id @default(cuid())
  name           String       @unique
  marketType     MarketType
  description    String
  winRatePct     Float        @default(0)
  maxDrawdownPct Float        @default(0)
  avgReturnPct   Float        @default(0)
  riskLevel      String       @default("Medium")
  createdAt      DateTime     @default(now())
  userAlgos      UserAlgo[]
  signals        AlgoSignal[]
  journalEntries TradeJournalEntry[]

  @@map("algos")
}

model UserAlgo {
  id        String    @id @default(cuid())
  userId    String
  algoId    String
  enabled   Boolean   @default(false)
  enabledAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  algo      Algo      @relation(fields: [algoId], references: [id], onDelete: Cascade)

  @@unique([userId, algoId])
  @@map("user_algos")
}

model AlgoSignal {
  id          String       @id @default(cuid())
  algoId      String
  instrument  String
  signal      SignalAction
  metric      Float?
  metricLabel String?
  timestamp   DateTime     @default(now())
  algo        Algo         @relation(fields: [algoId], references: [id], onDelete: Cascade)

  @@index([algoId, timestamp])
  @@map("algo_signals")
}

model TradeJournalEntry {
  id            String         @id @default(cuid())
  userId        String
  algoId        String?
  instrument    String
  direction     TradeDirection
  entryPrice    Float
  exitPrice     Float?
  entryTime     DateTime
  exitTime      DateTime?
  screenshotUrl String?
  reason        String?
  emotion       String?
  mistake       String?
  news          String?
  tags          TradeTag[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  algo          Algo?          @relation(fields: [algoId], references: [id], onDelete: SetNull)

  @@index([userId, entryTime])
  @@map("trade_journal_entries")
}

model ImpersonationLog {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String
  startedAt    DateTime @default(now())
  admin        User     @relation("ImpersonationAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser   User     @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetUserId])
  @@map("impersonation_logs")
}
